    "clsx": "^2.0.0",
    "downshift": "^8.1.0",
    "emittery": "^1.0.1",
    "immer": "^10.0.2",
    "lodash": "^4.17.21",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
