{
  "name": "devdocsai",
  "private": true,
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm pack --workspaces",
    "build:packages": "npm run build -w @devdocsai/core -w @devdocsai/docusaurus-theme-search -w @devdocsai/react -w @devdocsai/web",
    "lint": "run-p lint:css lint:format lint:js lint:md lint:ts",
    "lint:css": "npx stylelint \"**/*.css\"",
    "lint:format": "prettier --check .",
    "lint:js": "eslint . --quiet",
    "lint:md": "remark . --frail",
    "lint:ts": "npm run build && rm *.tgz",
    "prepare": "husky install",
    "publish": "npm run build:packages && changeset publish",
    "test": "vitest run --coverage",
    "version": "changeset version && npm install"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.2",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "typescript-eslint": "^8.59.3",
    "@vitest/coverage-v8": "^0.34.3",
    "@vitest/eslint-plugin": "^1.6.17",
    "ajv": "^8.17.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^16.5.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "msw": "^1.3.0",
    "npm-run-all": "^4.1.5",
    "path-exists-cli": "^2.0.0",
    "prettier": "^3.0.3",
    "prettier-plugin-packagejson": "^2.4.5",
    "remark-cli": "^11.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-toc": "^8.0.1",
    "remark-validate-links": "^13.0.0",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-formatter-github": "^1.0.1",
    "typescript": "~5.2.2",
    "unified-prettier": "^2.0.0",
    "vite": "^5.2.6",
    "vitest": "^0.34.3"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
